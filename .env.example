# ====== Tontom — variáveis de ambiente ======
# Copie para .env.local e preencha. NÃO commitar o .env.local.

# --- WhatsApp (Z-API) — modo atual / transição ---
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
WHATSAPP_NUMBER=            # número que recebe os leads (DDI+DDD), ex: 5549999999999
WHATSAPP_DEFAULT_MESSAGE=   # opcional, texto pré-preenchido
WEBHOOK_SECRET=             # segredo na URL do webhook do Z-API (?secret=...)

# --- WhatsApp Cloud API OFICIAL (WABA) — endgame ---
WHATSAPP_PHONE_NUMBER_ID=   # ID do número na Cloud API (Gerenciador do WhatsApp)
WHATSAPP_ACCESS_TOKEN=      # token permanente (system user)
WHATSAPP_WABA_ID=           # ID da conta WhatsApp Business
WHATSAPP_VERIFY_TOKEN=      # você inventa; usado na verificação do webhook da Meta
META_CTWA_DATASET_ID=       # dataset ligado à Página/WABA (recebe conversão CTWA via CAPI)

# --- Supabase (banco + auth) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Meta (Conversions API / CAPI) ---
META_PIXEL_ID=1215484877184351
META_CAPI_TOKEN=
META_TEST_EVENT_CODE=       # opcional, só pra testar eventos no Gerenciador
META_GRAPH_VERSION=         # opcional, default v21.0

# --- App ---
APP_BASE_URL=               # ex: https://tontom.vercel.app (preenche depois do deploy)
